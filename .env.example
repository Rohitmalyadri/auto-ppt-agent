# Auto-PPT Agent — Environment Configuration
# Copy this file to .env and fill in your key

# ── OpenRouter API Key ────────────────────────────────────────────────────────
# Get your free key at: https://openrouter.ai/keys
# Free models available: google/gemma-3-12b-it:free, mistralai/mistral-7b-instruct:free
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Web App Settings ──────────────────────────────────────────────────────────
FLASK_PORT=5000
FLASK_DEBUG=false

# ── Agent Settings ────────────────────────────────────────────────────────────
# MAX_SLIDES=10
# DEFAULT_SLIDES=5
